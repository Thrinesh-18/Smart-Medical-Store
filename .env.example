APP_NAME=Smart Medical Store IR System
ENV=development
DATABASE_URL=sqlite:///./data/medical_store.db
DATA_JSON_PATH=./data/medicines.json
DATA_CSV_PATH=./data/medicines.csv
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
BM25_WEIGHT=0.55
SEMANTIC_WEIGHT=0.45
MAX_RESULTS=20
CACHE_SIZE=2048
RATE_LIMIT_PER_MINUTE=120
